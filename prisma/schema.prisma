generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String               @id @default(cuid())
  email                    String               @unique
  name                     String
  password                 String
  createdAt                DateTime             @default(now())
  // When the user accepted Terms + Privacy (implicit consent at signup).
  // Null for accounts created before consent capture; their createdAt is the implicit proof.
  termsAcceptedAt          DateTime?
  profileImage             String?
  googleId                 String?              @unique
  lastActiveAt             DateTime?            @default(now())
  showOnline               Boolean              @default(true)
  emailVerificationExpires DateTime?
  emailVerificationToken   String?              @unique
  isEmailVerified          Boolean              @default(false)
  passwordResetExpires     DateTime?
  passwordResetToken       String?              @unique
  bio                      String?
  coverImage               String?
  location                 String?
  notifyComments           Boolean              @default(false)
  notifyCommunityJoins     Boolean              @default(true)
  notifyFollows            Boolean              @default(true)
  notifyLikes              Boolean              @default(false)
  notifyMentions           Boolean              @default(true)
  notifyNewPosts           Boolean              @default(false)
  refreshTokens            RefreshToken[]
  posts                    Post[]
  comments                 Comment[]
  communities              Community[]
  bans                     CommunityBan[]
  memberships              CommunityMember[]
  conversationsAsP1        Conversation[]       @relation("ConversationParticipant1")
  conversationsAsP2        Conversation[]       @relation("ConversationParticipant2")
  courseEnrollments        CourseEnrollment[]
  coursesCreated           Course[]
  lessonProgress           LessonProgress[]
  likes                    Like[]
  messagesSent             Message[]
  notificationsSent        Notification[]       @relation("NotificationActor")
  notifications            Notification[]       @relation("NotificationRecipient")
  savedPosts               SavedPost[]
  following                UserFollow[]         @relation("UserFollowing")
  followers                UserFollow[]         @relation("UserFollowers")
  paymentMethods           UserPaymentMethod[]
  pollVotes                PollVote[]
  // HYP customer object id; populated on first card tokenization (Phase 3).
  // Reused across all subsequent flows so we don't create duplicate customers.
  hypCustomerId            String?              @unique
  memberSubscriptions      MemberSubscription[]
  pendingCommunityCreation PendingCommunityCreation?
  // Withly platform plan (price/trial length/commission rate). Nullable
  // for legacy rows; new signups land on the default plan. Read via
  // user.plan.* instead of hardcoded constants.
  planId                   String?
  plan                     Plan?                @relation(fields: [planId], references: [id])

  @@index([lastActiveAt])
}

model RefreshToken {
  id           String    @id @default(cuid())
  userId       String
  tokenHash    String    @unique
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?
  // Set when this token is rotated; points to the new token's id.
  // Lets us detect refresh-token reuse (replay) by checking whether a
  // submitted token has already been replaced.
  replacedById String?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model UserPaymentMethod {
  id                  String               @id @default(cuid())
  userId              String
  cardLastFour        String
  cardBrand           String               @default("Visa")
  createdAt           DateTime             @default(now())
  isPrimary           Boolean              @default(false)
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  // HYP-tokenized payment method id. Null on rows that predate HYP wiring;
  // backfilled lazily on next card-update (Phase 6.1).
  hypPaymentMethodId  String?              @unique
  // Card expiry from HYP's Tokef (YYMM) on getToken. Required to build
  // Tmonth/Tyear on every recurring SOFT charge — HYP doesn't store validity
  // with the token. NULL pre-HYP and until Phase 3 token capture populates.
  cardExpMonth        Int?
  cardExpYear         Int?
  // Reverse relations: communities and member subscriptions billing on this card.
  communitiesBilled   Community[]
  memberSubscriptions MemberSubscription[]

  @@map("user_payment_methods")
}

// Withly platform plans (paid by owners to Withly). Each plan stores its
// own price, trial length, and commission rate so the codebase reads
// these values off the user's plan row instead of hardcoded constants.
// Pre-launch there's one plan (slug=community); the schema is shaped so
// adding Pro/Enterprise later is INSERT, not migration.
model Plan {
  id                    String   @id @default(cuid())
  slug                  String   @unique
  name                  String
  // Monthly platform fee in ILS, paid by the owner to Withly.
  monthlyPriceILS       Int
  // Commission Withly takes from member subscriptions (community.price * rate).
  // Basis points — 500 = 5.00%. Avoids floating-point drift in billing math.
  commissionBasisPoints Int      @default(500)
  // Owner trial length in months before first SOFT charge fires.
  trialLengthMonths     Int      @default(1)
  // Soft-retire pattern: flip false instead of deleting so existing
  // user.planId references stay valid.
  isActive              Boolean  @default(true)
  // The plan new signups land on when they don't pick. Exactly one
  // active plan should have this true at any time (app-level invariant).
  isDefault             Boolean  @default(false)
  // Structured feature list. Json so we can add maxMembers / videoQuotaGB /
  // etc. later without migrations. Null for plans with no extra features.
  features              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  users                 User[]

  @@index([isActive])
  @@map("plans")
}

// Staging row for the pricing-checkout flow: the user fills out the new-community
// form, we stash the data here, then open the HYP tokenize iframe. Only on
// successful tokenize is the real Community row created (atomic with payment-method
// bind) and this row deleted. Without this staging step, a community would exist
// in DRAFT before the owner had a card on file — which is meaningless for a
// SaaS that charges the owner for hosting. Abandoned rows are deleted by the
// daily cron after 24h (R2 files cleaned in the same pass).
model PendingCommunityCreation {
  id                String   @id @default(cuid())
  userId            String   @unique
  name              String
  description       String
  topic             String?
  image             String?
  logo              String?
  price             Float?   @default(0)
  youtubeUrl        String?
  whatsappUrl       String?
  facebookUrl       String?
  instagramUrl      String?
  galleryImages     String[]
  galleryVideos     String[]
  showOnlineMembers Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("pending_community_creations")
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("user_follows")
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  recipientId String
  actorId     String?
  postId      String?
  communityId String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  actor       User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  recipient   User             @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead])
  @@index([recipientId, createdAt])
  @@index([actorId])
  @@map("notifications")
}

model Community {
  id                      String                      @id @default(cuid())
  name                    String
  description             String
  // Nullable for owner-account-deletion wind-down (Phase 5 Mission 4).
  // When the owner deletes their account, this becomes NULL via SetNull
  // and the community lingers (read-only via existing SUSPENDED rules)
  // until grace ends and the new hard-delete cron pass removes it.
  ownerId                 String?
  createdAt               DateTime                    @default(now())
  image                   String?
  topic                   String?
  facebookUrl             String?
  galleryImages           String[]
  galleryVideos           String[]
  instagramUrl            String?
  whatsappUrl             String?
  youtubeUrl              String?
  rules                   String[]
  price                   Float?                      @default(0)
  logo                    String?
  cardBrand               String?
  cardLastFour            String?
  trialStartDate          DateTime?
  showOnlineMembers       Boolean                     @default(true)
  status                  CommunityStatus             @default(DRAFT)
  subscriptionStatus      CommunitySubscriptionStatus @default(ACTIVE)
  suspendedAt             DateTime?
  subscriptionCancelledAt DateTime?
  pendingPrice            Float?
  pendingPriceEffectiveAt DateTime?
  priceChangeAnnouncedAt  DateTime?
  // Daily cron sets this when it sends the 7-day-before reminder so the
  // reminder fires exactly once per scheduled price change. Cleared
  // alongside pendingPrice when the change applies or gets cancelled.
  priceChangeReminderSentAt DateTime?
  // Same pattern for the 7-day-before-suspension reminder: cron sends
  // once, sets this timestamp, won't resend if the cancellation is
  // unrevoked-then-rescheduled (caller clears it when needed).
  suspensionReminderSentAt  DateTime?
  // Phase 4 Mission 4.1a — once-only stamp for the 3-day pre-trial-end
  // reminder email. The cron picks up communities where the first
  // SOFT charge is 2-4 days out, sends the reminder, sets this
  // timestamp. Never cleared (no "restart trial" flow today).
  trialEndReminderSentAt    DateTime?
  // Phase 5 Mission 4 — terminal flag set when the owner deletes their
  // account. Distinct from subscriptionCancelledAt (owner-cancel, which
  // can be reversed). Once set, the existing cancel cron flips the
  // community to SUSPENDED at grace-end, and a new hard-delete cron
  // pass then removes the community + its R2 files.
  ownerDeletedAt          DateTime?
  slug                    String?                     @unique
  // HYP-era billing fields (added Phase 1.2). Old cardLastFour/cardBrand
  // strings stay until Phase 6.1 backfill is verified, then dropped.
  paymentMethodId         String?
  paymentMethod           UserPaymentMethod?          @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  hypSubscriptionId       String?                     @unique
  nextBillingDate         DateTime?
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  posts                   Post[]
  owner                   User?                       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  bans                    CommunityBan[]
  members                 CommunityMember[]
  courses                 Course[]
  events                  Event[]
  memberSubscriptions     MemberSubscription[]

  @@map("communities")
}

model CommunityMember {
  id                            String     @id @default(cuid())
  userId                        String
  communityId                   String
  joinedAt                      DateTime   @default(now())
  role                          MemberRole @default(USER)
  // Set to community.pendingPriceEffectiveAt when the member dismisses the
  // price-change announcement popup. Compared against the community's
  // pendingPriceEffectiveAt to decide whether to show the popup again.
  priceChangeSeenForEffectiveAt DateTime?
  // Set to community.subscriptionCancelledAt when the member dismisses the
  // scheduled-suspension popup. Same compare-and-show pattern as above.
  suspensionScheduledSeenAt     DateTime?
  community                     Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user                          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
  @@index([communityId])
  @@map("community_members")
}

model CommunityBan {
  id          String    @id @default(cuid())
  userId      String
  communityId String
  bannedAt    DateTime  @default(now())
  // null expiresAt means indefinite — ban is active until liftBan deletes the row.
  // Existing time-limited bans keep their expiresAt and auto-expire as before.
  expiresAt   DateTime?
  reason      String?
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
  @@index([communityId, expiresAt])
  @@map("community_bans")
}

model Post {
  id          String      @id @default(cuid())
  content     String
  createdAt   DateTime    @default(now())
  // Nullable to support author-account-deletion anonymization (Phase 5
  // Mission 2). NULL means the original author deleted their account;
  // the post survives in the community feed as "משתמש שנמחק".
  authorId    String?
  communityId String
  title       String?
  isPinned    Boolean     @default(false)
  pinnedAt    DateTime?
  files       Json[]
  images      String[]
  videos      String[]
  links       String[]
  category    String?
  author      User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)
  community   Community   @relation(fields: [communityId], references: [id], onDelete: Cascade)
  comments    Comment[]
  likes       Like[]
  poll        Poll?
  savedBy     SavedPost[]

  @@index([communityId, createdAt])
  @@index([authorId])
}

model Poll {
  id        String       @id @default(cuid())
  question  String
  postId    String       @unique
  createdAt DateTime     @default(now())
  expiresAt DateTime?
  options   PollOption[]
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("polls")
}

model PollOption {
  id     String     @id @default(cuid())
  text   String
  pollId String
  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes  PollVote[]

  @@map("poll_options")
}

model PollVote {
  id        String     @id @default(cuid())
  optionId  String
  // Nullable for voter-deletion anonymization (Phase 5 Mission 2).
  // Preserves vote counts after the voter deletes their account.
  userId    String?
  createdAt DateTime   @default(now())
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([optionId, userId])
  @@map("poll_votes")
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  // Nullable for liker-deletion anonymization (Phase 5 Mission 2).
  // Preserves like counts after the liker deletes their account.
  userId    String?
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([userId, postId])
  @@index([postId])
  @@map("likes")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  // Nullable for author-deletion anonymization (Phase 5 Mission 2).
  userId    String?
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@map("comments")
}

model SavedPost {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@map("saved_posts")
}

model Event {
  id             String      @id @default(cuid())
  title          String
  description    String?
  coverImage     String?
  date           DateTime
  endDate        DateTime?
  duration       Int?
  timezone       String      @default("Asia/Jerusalem")
  isRecurring    Boolean     @default(false)
  recurringType  String?
  locationType   String      @default("online")
  locationName   String?
  locationUrl    String?
  category       String?
  capacity       Int?
  sendReminders  Boolean     @default(true)
  reminderDays   Int         @default(1)
  reminderSentAt DateTime?
  attendeeType   String      @default("all")
  communityId    String
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  rsvps          EventRsvp[]
  community      Community   @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@map("events")
}

model EventRsvp {
  id        String     @id @default(cuid())
  eventId   String
  userId    String
  status    RsvpStatus @default(GOING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@map("event_rsvps")
}

model Conversation {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  participant1Id  String
  participant2Id  String
  lastMessageAt   DateTime?
  lastMessageText String?
  participant1    User      @relation("ConversationParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2    User      @relation("ConversationParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages        Message[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  isRead         Boolean      @default(false)
  senderId       String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model Course {
  id          String             @id @default(cuid())
  title       String
  description String
  image       String?
  duration    Int                @default(0)
  isPublished Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  communityId String
  // Nullable for author-deletion anonymization (Phase 5 Mission 2).
  authorId    String?
  chapters    Chapter[]
  enrollments CourseEnrollment[]
  author      User?              @relation(fields: [authorId], references: [id], onDelete: SetNull)
  community   Community          @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@map("courses")
}

model Chapter {
  id       String   @id @default(cuid())
  title    String
  order    Int      @default(0)
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  @@index([courseId])
  @@map("chapters")
}

model Lesson {
  id           String           @id @default(cuid())
  title        String
  content      String?
  videoUrl     String?
  duration     Int              @default(0)
  order        Int              @default(0)
  chapterId    String
  files        Json[]
  images       String[]
  lessonType   String           @default("content")
  links        String[]
  contentOrder String[]         @default(["video", "text", "links", "images"])
  progress     LessonProgress[]
  quiz         LessonQuiz?
  chapter      Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@map("lessons")
}

model LessonQuiz {
  id        String               @id @default(cuid())
  lessonId  String               @unique
  questions LessonQuizQuestion[]
  lesson    Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_quizzes")
}

model LessonQuizQuestion {
  id           String             @id @default(cuid())
  question     String
  questionType String             @default("radio")
  order        Int                @default(0)
  quizId       String
  options      LessonQuizOption[]
  quiz         LessonQuiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("lesson_quiz_questions")
}

model LessonQuizOption {
  id         String             @id @default(cuid())
  text       String
  isCorrect  Boolean            @default(false)
  order      Int                @default(0)
  questionId String
  question   LessonQuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("lesson_quiz_options")
}

model CourseEnrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  progress    Float     @default(0)
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("course_enrollments")
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("lesson_progress")
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  NEW_POST
  MENTION
  COMMUNITY_JOIN
  COMMUNITY_BAN
  COMMUNITY_BAN_LIFTED
  COMMUNITY_SCHEDULED_FOR_SUSPENSION
  COMMUNITY_SUSPENDED
  COMMUNITY_REACTIVATED
  // Member gets a bell-icon entry when the owner announces a price
  // change. Mirrors the existing email + popup so users who don't open
  // the community between announcement and effective-date still know.
  PRICE_CHANGE_ANNOUNCED
  // User gets a bell-icon entry alongside the event reminder email.
  // Closes the email-only gap — active users see the reminder in-app
  // without checking inbox.
  EVENT_REMINDER
  // Owner gets a bell-icon entry alongside the email when a recurring
  // SOFT charge fails. Highest-stakes notification — losing email
  // visibility while a community is heading toward suspension is a
  // serious failure mode. (Fires from Phase 4 cron, not yet wired.)
  PAYMENT_FAILED
}

enum CommunityStatus {
  DRAFT
  PRIVATE
  PUBLIC
}

enum CommunitySubscriptionStatus {
  ACTIVE
  SUSPENDED
}

enum MemberRole {
  MANAGER
  USER
}

enum RsvpStatus {
  GOING
  MAYBE
  NOT_GOING
}

// Per-member billing record for paid communities (added Phase 1.2 of HYP
// integration). One row per (user, community) when a member joins a paid
// community via HYP. Pre-HYP this table is empty — populated only after
// HYP wiring lands and members start being charged for joining.
model MemberSubscription {
  id                 String                   @id @default(cuid())
  userId             String
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  communityId        String
  community          Community                @relation(fields: [communityId], references: [id], onDelete: Cascade)
  paymentMethodId    String?
  paymentMethod      UserPaymentMethod?       @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  hypSubscriptionId  String                   @unique
  // Locks in the price the member started at — replaces the placeholder of
  // reading the current `community.price` when computing historical revenue.
  priceAtJoin        Float
  nextBillingDate    DateTime
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  status             MemberSubscriptionStatus @default(ACTIVE)
  // Set when the member requested to leave; HYP keeps charging until
  // `currentPeriodEnd`, then sub auto-cancels.
  cancelledAt        DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([userId])
  @@index([communityId])
  @@index([status])
  @@map("member_subscriptions")
}

enum MemberSubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  ENDED
}
